# SQL Server - for load_leads_to_sql.py
# Local Docker: SQL_SERVER=localhost or 127.0.0.1
# Azure SQL (Mac): SQL_SERVER=yourserver.database.windows.net
SQL_SERVER=localhost
SQL_SERVER_PORT=1433
# For local SQL only: Self-hosted IR name. Leave unset for Azure SQL.
# SELF_HOSTED_IR_NAME=SelfHostedIR
SQL_DATABASE=LeadManagement
SQL_USER=sa
SQL_PASSWORD=Bh@utik00
# Or use a single connection string:
# SQL_SERVER_CONNECTION_STRING=DRIVER={ODBC Driver 18 for SQL Server};SERVER=localhost,1433;DATABASE=LeadManagement;UID=sa;PWD=xxx;TrustServerCertificate=yes;

# Snowflake - for scripts/transform_leads_to_leadevents.py and scripts/setup_adf_config.py
SNOWFLAKE_ACCOUNT=your-org-account
SNOWFLAKE_DATABASE=LEADMANAGEMENT
SNOWFLAKE_WAREHOUSE=LEAD_WH
SNOWFLAKE_SCHEMA=PUBLIC
SNOWFLAKE_USER=your-snowflake-username
SNOWFLAKE_PASSWORD=your-snowflake-password
