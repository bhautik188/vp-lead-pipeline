{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "lead-adf"
		},
		"LsSnowflake_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'LsSnowflake'"
		},
		"LsSqlServer_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'LsSqlServer'"
		},
		"LsAzureBlobStaging_sasUri": {
			"type": "secureString",
			"metadata": "Secure string for 'sasUri' of 'LsAzureBlobStaging'"
		},
		"LsSnowflake_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "LEADMANAGEMENT"
		},
		"LsSnowflake_properties_typeProperties_role": {
			"type": "string",
			"defaultValue": "ACCOUNTADMIN"
		},
		"LsSnowflake_properties_typeProperties_host": {
			"type": "string",
			"defaultValue": "IWXPGGB-SQ54018.snowflakecomputing.com"
		},
		"LsSqlServer_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "tcp:lead-sql.database.windows.net,1433"
		},
		"LsSqlServer_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "LeadManagement"
		},
		"LsSqlServer_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "sqladmin"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "lead-adf_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"LsSnowflake_password": {
						"value": "[parameters('LsSnowflake_password')]"
					},
					"LsSqlServer_password": {
						"value": "[parameters('LsSqlServer_password')]"
					},
					"LsAzureBlobStaging_sasUri": {
						"value": "[parameters('LsAzureBlobStaging_sasUri')]"
					},
					"LsSnowflake_properties_typeProperties_database": {
						"value": "[parameters('LsSnowflake_properties_typeProperties_database')]"
					},
					"LsSnowflake_properties_typeProperties_role": {
						"value": "[parameters('LsSnowflake_properties_typeProperties_role')]"
					},
					"LsSnowflake_properties_typeProperties_host": {
						"value": "[parameters('LsSnowflake_properties_typeProperties_host')]"
					},
					"LsSqlServer_properties_typeProperties_server": {
						"value": "[parameters('LsSqlServer_properties_typeProperties_server')]"
					},
					"LsSqlServer_properties_typeProperties_database": {
						"value": "[parameters('LsSqlServer_properties_typeProperties_database')]"
					},
					"LsSqlServer_properties_typeProperties_userName": {
						"value": "[parameters('LsSqlServer_properties_typeProperties_userName')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}